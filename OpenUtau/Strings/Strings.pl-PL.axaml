  <system:String x:Key="dialogs.exportds.pitch">Wysokość (f0)</system:String>
  <system:String x:Key="dialogs.exportds.variance">Wyrażenia ekspresji</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Włącz pamięć podręczną tensora Diffsinger w preferencjach, żeby eksportować wyrażenia ekspresji
</system:String>

  Nowe BPM:</system:String>
  <system:String x:Key="dialogs.splitpart.caption">Rozdzielanie części</system:String>
  <system:String x:Key="dialogs.splitpart.intheway">Jedna lub więcej nut pokrywa się ze wskaźnikiem odtwarzania. Czy chcesz kontynuować dzielenie części na najbliższej pozycji wskaźnika, przy której nie ma nut?</system:String>
